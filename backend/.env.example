# PantryKeeper backend — environment template
# Copy to `.env` and fill in real values. Never commit `.env`.

# -- Database ---------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://inventory_user:password@db:5432/inventory

# -- Auth -------------------------------------------------------------------
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-me
# Optional overrides (defaults shown):
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# -- CORS -------------------------------------------------------------------
# Comma-separated origins. Unset = dev defaults (localhost regex).
# CORS_ALLOW_ORIGINS=https://app.example.com,https://staging.example.com

# -- Public URL + deep linking ---------------------------------------------
# Used to build the Microsoft OAuth redirect URI. Must match what's registered
# in the Entra app registration (Authentication -> Web platform).
PUBLIC_BASE_URL=https://warehouse.steinarey.is

# Scheme used to bounce the user from the system browser back into the app
# after OAuth. Must match the intent-filter in AndroidManifest.xml.
APP_DEEP_LINK_SCHEME=pantrykeeper

# -- Microsoft To Do connector ---------------------------------------------
# Leave MICROSOFT_CLIENT_ID empty to disable the connector (endpoints 503).
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# `common` accepts personal MSAs (where consumer To Do lives) + work/school.
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/common
MICROSOFT_SCOPES=Tasks.ReadWrite User.Read offline_access

# Background sync cadence (seconds). 600 = 10 min.
MS_TODO_SYNC_INTERVAL_SECONDS=600

# -- Connector token encryption --------------------------------------------
# Fernet key (URL-safe base64, 32 bytes). Used to encrypt OAuth tokens at rest.
# Generate ONCE and keep safe. Losing it = admin must disconnect + re-OAuth.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_ENCRYPTION_KEY=
